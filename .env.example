# ── Copy this file to .env and fill in your values ──────────────
# NEVER commit .env to Git

# App
APP_ENV=development
APP_SECRET_KEY=your-super-secret-key-change-this-in-production
APP_NAME=CreditIQ

# Database (SQL Server)
# Format: mssql+pyodbc://USER:PASSWORD@HOST:PORT/DB?driver=ODBC+Driver+18+for+SQL+Server
DATABASE_URL=mssql+pyodbc://sa:CreditIQ_Pass123!@localhost:1433/creditiq_db?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# For Windows Authentication (no username/password needed):
# DATABASE_URL=mssql+pyodbc://@localhost:1433/creditiq_db?driver=ODBC+Driver+18+for+SQL+Server&trusted_connection=yes

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# External APIs
FRED_API_KEY=your_fred_api_key_here
# Get yours free at: https://fred.stlouisfed.org/docs/api/api_key.html

# Kaggle (for data download)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# MLflow
MLFLOW_TRACKING_URI=./mlflow_runs
MLFLOW_EXPERIMENT_NAME=creditiq

# Model paths
XGBOOST_MODEL_PATH=./models/xgboost/model.pkl
FINBERT_MODEL_PATH=./models/finbert/
LSTM_MODEL_PATH=./models/lstm/model.pt
ENSEMBLE_MODEL_PATH=./models/ensemble/model.pkl
